---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner section">
    <div class="footer-top">
      <a href="#hero" class="footer-logo">
        <span class="logo-symbol">K</span><span>jihoon</span>
      </a>
      <div class="footer-links">
        <a href="https://github.com/username" target="_blank" rel="noopener noreferrer" class="footer-link">
          GitHub
        </a>
        <span class="footer-divider">/</span>
        <a href="mailto:contact@example.com" class="footer-link">
          Email
        </a>
      </div>
    </div>
    <p class="footer-copy">
      &copy; {year} Jihoon Kim. Built with Astro.
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 48px 24px;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 2px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .footer-logo:hover {
    color: var(--text-primary);
  }

  .footer-logo .logo-symbol {
    color: var(--accent-gold);
    font-weight: 800;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-link {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--accent-gold);
  }

  .footer-divider {
    color: var(--text-muted);
    opacity: 0.4;
    font-size: 12px;
  }

  .footer-copy {
    font-size: 13px;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .footer-top {
      flex-direction: column;
      gap: 16px;
      align-items: flex-start;
    }
  }
</style>
