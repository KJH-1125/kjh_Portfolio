---
const contacts = [
  {
    label: 'Name',
    value: '김진혁',
    icon: 'person',
  },
  {
    label: 'Phone',
    value: '010-6275-3895',
    href: 'tel:010-6275-3895',
    icon: 'phone',
  },
  {
    label: 'Email',
    value: 'rlawlsgur135@gmail.com',
    href: 'mailto:rlawlsgur135@gmail.com',
    icon: 'email',
  },
  {
    label: 'GitHub',
    value: 'KJH-1125',
    href: 'https://github.com/KJH-1125',
    icon: 'github',
  },
];
---

<section class="contact-section" id="contact">
  <div class="section">
    <div class="section-label reveal">Contact</div>
    <h2 class="section-title reveal reveal-delay-1">연락처</h2>

    <div class="contact-card reveal reveal-delay-2">
      <dl class="contact-list">
        {
          contacts.map((item) => (
            <div class="contact-item">
              <dt class="contact-label">
                <span class="contact-icon" data-icon={item.icon}>
                  {item.icon === 'person' && (
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="8" r="4" />
                      <path d="M20 21a8 8 0 0 0-16 0" />
                    </svg>
                  )}
                  {item.icon === 'phone' && (
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                  )}
                  {item.icon === 'email' && (
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="4" width="20" height="16" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  )}
                  {item.icon === 'github' && (
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                    </svg>
                  )}
                </span>
                {item.label}
              </dt>
              <dd class="contact-value">
                {item.href ? (
                  <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                    {item.value}
                  </a>
                ) : (
                  <span>{item.value}</span>
                )}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding-top: var(--section-gap);
    padding-bottom: var(--section-gap);
    position: relative;
  }

  .contact-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(600px, 80%);
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--border) 20%,
      var(--accent-gold-dim) 50%,
      var(--border) 80%,
      transparent
    );
  }

  .contact-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 40px;
    max-width: 560px;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .contact-label {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--accent-gold-dim);
    border-radius: 8px;
    color: var(--accent-gold);
    flex-shrink: 0;
  }

  .contact-value {
    font-size: 15px;
    color: var(--text-secondary);
    text-align: right;
  }

  .contact-value a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .contact-value a:hover {
    color: var(--accent-gold);
  }

  @media (max-width: 640px) {
    .contact-card {
      padding: 28px 24px;
    }

    .contact-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }

    .contact-value {
      text-align: left;
      padding-left: 48px;
    }
  }
</style>
