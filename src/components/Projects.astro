---
import { projects } from '../data/projects';
---

<section class="projects-section" id="projects">
  <div class="section">
    <div class="section-label reveal">Projects</div>
    <h2 class="section-title reveal reveal-delay-1">만들어 온 것들</h2>

    <div class="projects-grid">
      {
        projects.map((project, i) => (
          <article class={`project-card reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            {/* Card top accent */}
            <div class="card-accent" />

            <div class="card-body">
              {/* Domain category + web badge */}
              <div class="card-meta">
                <span class="card-category">{project.category}</span>
                {project.web && <span class="card-web">Web</span>}
              </div>

              <h3 class="card-title">{project.title}</h3>
              <p class="card-desc">{project.description}</p>

              {project.role && (
                <p class="card-role">
                  <span class="card-role-label">역할</span>
                  {project.role}
                </p>
              )}

              {project.highlights && (
                <ul class="card-highlights">
                  {project.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              )}

              {project.impact && <p class="card-impact">{project.impact}</p>}

              <div class="card-tags">
                {project.tags.map((tag) => (
                  <span class="card-tag">{tag}</span>
                ))}
              </div>
            </div>

            <div class="card-footer">
              {project.github || project.demo ? (
                <>
                  {project.github && (
                    <a href={project.github} target="_blank" rel="noopener noreferrer" class="card-link">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                      </svg>
                      Code
                    </a>
                  )}
                  {project.demo && (
                    <a href={project.demo} target="_blank" rel="noopener noreferrer" class="card-link card-link--demo">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                      </svg>
                      Demo
                    </a>
                  )}
                </>
              ) : (
                <span class="card-private">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                  </svg>
                  사내 시스템 · 코드 비공개
                </span>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding-top: var(--section-gap);
    padding-bottom: var(--section-gap);
    position: relative;
  }

  .projects-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(600px, 80%);
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--border) 20%,
      var(--accent-gold-dim) 50%,
      var(--border) 80%,
      transparent
    );
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  /* ── Card ── */
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition:
      border-color 0.3s,
      transform 0.35s var(--ease-out-expo),
      box-shadow 0.35s ease;
  }

  .project-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-4px);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(232, 196, 104, 0.05);
  }

  .card-accent {
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--accent-gold) 0%,
      rgba(232, 196, 104, 0.1) 100%
    );
    opacity: 0;
    transition: opacity 0.35s;
  }

  .project-card:hover .card-accent {
    opacity: 1;
  }

  .card-body {
    flex: 1;
    padding: 28px 28px 20px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 18px;
  }

  .card-category {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--accent-gold);
    letter-spacing: 0.04em;
    padding: 5px 10px 5px 12px;
    background: var(--accent-gold-dim);
    border-left: 2px solid var(--accent-gold);
    border-radius: 0 4px 4px 0;
  }

  .card-web {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--accent-teal);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 9px;
    border: 1px solid rgba(94, 234, 212, 0.25);
    border-radius: 999px;
    flex-shrink: 0;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 18px;
  }

  /* ── Role ── */
  .card-role {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 14px;
  }

  .card-role-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-right: 8px;
  }

  .card-role-label::after {
    content: '·';
    margin-left: 8px;
    color: var(--border);
  }

  /* ── Highlights ── */
  .card-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-bottom: 18px;
  }

  .card-highlights li {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
    padding-left: 15px;
    position: relative;
  }

  .card-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 5px;
    height: 1px;
    background: var(--accent-gold);
  }

  .card-impact {
    font-size: 13px;
    color: var(--accent-gold);
    line-height: 1.6;
    margin-bottom: 18px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .card-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 4px 10px;
    background: var(--bg-card);
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  /* ── Card footer ── */
  .card-footer {
    display: flex;
    gap: 12px;
    padding: 16px 28px 24px;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .card-link:hover {
    color: var(--text-primary);
  }

  .card-link--demo:hover {
    color: var(--accent-teal);
  }

  .card-private {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .card-private svg {
    color: var(--accent-gold);
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
