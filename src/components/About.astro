---
import { skills } from '../data/skills';
---

<section class="about-section" id="about">
  <div class="section">
    <div class="section-label reveal">About</div>
    <h2 class="section-title reveal reveal-delay-1">저를 소개합니다</h2>

    <div class="about-grid">
      <!-- Profile -->
      <div class="about-text reveal reveal-delay-2">
        <p>
          안녕하세요, 프론트엔드 개발자 <strong>김진혁</strong>입니다.
        </p>
        <p>
          사용자가 자연스럽게 느끼는 인터페이스, 눈에 보이지 않는 곳까지 꼼꼼하게 신경 쓰는 개발을 지향합니다.
          복잡한 문제를 단순하게 풀어내는 과정에서 가장 큰 즐거움을 느끼며,
          팀과 함께 성장하는 것을 중요하게 생각합니다.
        </p>
        <p>
          새로운 기술을 배우는 것을 즐기고, 배운 것을 정리하고 공유하는 습관을 가지고 있습니다.
          현재는 React와 TypeScript를 중심으로 모던 웹 개발에 집중하고 있습니다.
        </p>

        <div class="about-links">
          <a href="https://github.com/username" target="_blank" rel="noopener noreferrer" class="about-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a href="mailto:contact@example.com" class="about-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            Email
          </a>
        </div>
      </div>

      <!-- Skills -->
      <div class="skills-panel reveal reveal-delay-3">
        {
          skills.map((group) => (
            <div class="skill-group">
              <h3 class="skill-category">{group.category}</h3>
              <div class="skill-tags">
                {group.items.map((item) => (
                  <span class="skill-tag">{item}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding-top: var(--section-gap);
    padding-bottom: var(--section-gap);
    position: relative;
  }

  /* Subtle top border glow */
  .about-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(600px, 80%);
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--border) 20%,
      var(--accent-gold-dim) 50%,
      var(--border) 80%,
      transparent
    );
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .about-text p {
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.85;
    margin-bottom: 20px;
  }

  .about-text p strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .about-links {
    display: flex;
    gap: 16px;
    margin-top: 32px;
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition:
      color 0.2s,
      border-color 0.2s,
      background 0.2s;
  }

  .about-link:hover {
    color: var(--accent-gold);
    border-color: rgba(232, 196, 104, 0.25);
    background: var(--accent-gold-glow);
  }

  /* ── Skills panel ── */
  .skills-panel {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding: 32px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 16px;
  }

  .skill-group {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .skill-category {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-tag {
    padding: 6px 14px;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition:
      color 0.2s,
      border-color 0.25s,
      background 0.2s,
      transform 0.25s var(--ease-out-expo);
  }

  .skill-tag:hover {
    color: var(--accent-gold);
    border-color: rgba(232, 196, 104, 0.2);
    background: var(--accent-gold-glow);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
